@model RestaurantOrderSystem.Domain.Entities.Item
@{
    ViewData["Title"] = "Confirm to Delete Item";
}

<h3>Are you sure you want to delete this?</h3>
<div>
    <dl>
        <dt>Name</dt>
        <dd>@Model.Name</dd>

        <dt>Description</dt>
        <dd>@Model.Description</dd>

        <dt>Price</dt>
        <dd>@Model.Price</dd>
    </dl>

  
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        @Html.AntiForgeryToken()

        <button type="submit" class="btn btn-danger">Yes, Delete it!</button>
        <a asp-action="Index" class="btn btn-secondary">No, take me back</a>
    </form>
</div>
